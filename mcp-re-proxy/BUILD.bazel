# MCPS-015/016: server-side sidecar library. Pure — depends only on the
# verification crate plus serde_json. Transport is layered on by the conformance
# harnesses (MCPS-017); the stdio-first binary entry arrives there too.
nt_rust_library(
    name = "mcp_re_proxy",
    srcs = _PROXY_LIB_SRCS,
    crate_name = "mcp_re_proxy",
    edition = "2021",
    deps = _PROXY_LIB_DEPS + _PROXY_LINUX_SANDBOX_DEPS,
)

# MCPS-079 — a SEPARATE library instance of mcp-re-proxy built WITH the fault
# feature, so the faulted CLIENT verifier is compiled into the fault-injection
# test. The default `:mcp_re_proxy` above is never built with this feature;
# production and the default `bazel test //...` link only the verifying instance.
nt_rust_library(
    name = "mcp_re_proxy_fault",
    srcs = _PROXY_LIB_SRCS,
    crate_features = ["fault_accept_any_client"],
    crate_name = "mcp_re_proxy",
    edition = "2021",
    deps = _PROXY_LIB_DEPS + _PROXY_LINUX_SANDBOX_DEPS,
)

# MCPS-079 — fault injection ("test of the tests"), the symmetric mirror of
# mcp-re-transport's fault_injection_test. Runs on EVERY `bazel test //...` (NOT
# `manual`) so the control can never silently rot. It DELIBERATELY breaks the
# CLIENT-authentication control by compiling both the library dep AND this test
# with `--features fault_accept_any_client`, then drives the SAME scenarios as
# tls_test's T1 (missing client cert) and T2 (untrusted client cert) and asserts
# the OPPOSITE outcome — the handshake now COMPLETES and the inner handler is
# reached — proving those rejection guards are load-bearing. The feature is off by
# default and only this separate `:mcp_re_proxy_fault` instance turns it on; the
# production `:mcp_re_proxy` / CLI are never built with it.
nt_rust_test(
    name = "fault_injection_test",
    srcs = ["tests/fault_injection_test.rs"],
    auto_cargo_toml = False,
    bazel_build_cfg = False,
    crate_features = ["fault_accept_any_client"],
    edition = "2021",
    deps = [
        ":mcp_re_proxy_fault",  # keep
        "@crates_mcp_re//:rcgen",
        "@crates_mcp_re//:rustls",
        "@crates_mcp_re//:rustls-pki-types",
    ],
)

