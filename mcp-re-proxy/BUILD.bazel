# ADR-MCPS-048 / MCPS-69 — these HITL live-cloud KMS tests are intentionally
# cargo-only (no Bazel target): each is `#![cfg(feature = "…kms…")]` + `#[ignore]`
# and runs ONLY in the manual live-infra lane (`cargo test --features … --
# --ignored` against real AWS/GCP KMS):
#   tests/aws_kms_live_test.rs, tests/gcp_kms_live_test.rs,
#   tests/gcp_kms_draft02_live_test.rs, tests/gcp_kms_delegated_tls_live_test.rs
# NOTE: gazelle_rust's `generate_from_cargo` mode enumerates test targets from
# Cargo metadata, so `# gazelle:exclude <file>` does NOT suppress them — gazelle
# will always PROPOSE a target for each in `-mode diff`. This is a documented
# advisory-diff false-positive; MCPS-70's staleness gate must allowlist them (and
# not auto-adopt gazelle write output wholesale). Do NOT add Bazel targets here.

# Single source of truth for the mcp_re_proxy library sources. The default
# `:mcp_re_proxy` library and the feature-flavored `:mcp_re_proxy_fault` /
# `:mcp_re_proxy_dev_env` instances (each a full rebuild of the same crate under a
# `#[cfg(feature = ...)]` fault/dev gate) ALL compile this exact file set — sharing
# the list here prevents the instances from silently drifting apart.
_PROXY_LIB_SRCS = [
    # ADR-MCPS-022: explicit authorized server key-set + per-audience response-
    # signing identity mode (per_node_keyset / shared_remote_signer).
    "src/authorized_keyset.rs",
    # ADR-MCPS-028 §B: native AWS KMS Ed25519 response signer (blocking ureq HTTPS +
    # minimal audited SigV4; behind #[cfg(feature = "aws_kms_keysource")], cfg'd out
    # of the default build). No async aws-sdk-kms/tokio (ADR-MCPS-018 lean-sync).
    "src/aws_kms_keysource.rs",
    "src/aws_sigv4.rs",
    "src/cli.rs",
    # ADR-MCPRE-051 §6 (MCPRE-116): versioned serving-config snapshot + in-process
    # CRL hot-reloader. Pure std; always compiled by every flavor.
    "src/config_snapshot.rs",
    # ADR-MCPS-028 §C: native GCP Cloud KMS Ed25519 response signer (blocking ureq
    # HTTPS + OAuth2 bearer; behind #[cfg(feature = "gcp_kms_keysource")], cfg'd out
    # of the default build). No async google-cloud SDK (ADR-MCPS-018 lean-sync).
    "src/gcp_kms_keysource.rs",
    # Issue #3838 (ADR-MCPS-014): non-exporting reference ResponseSigner proving the
    # response-signing delegation seam. Always compiled; default-build, Bazel-tested.
    "src/delegated_response_signer.rs",
    # ADR-MCPS-028 §G: delegated TLS handshake signing (rustls SigningKey fronting a
    # non-exporting device/KMS). Generic mechanism, always compiled.
    "src/delegated_tls.rs",
    "src/durable_replay.rs",
    "src/inner_launch.rs",
    "src/key_source.rs",
    # ADR-MCPS-028: provider-agnostic cloud-KMS response signer core (the shared
    # protocol mapping behind the #3838 delegation seam). Always compiled.
    "src/kms_keysource.rs",
    "src/lib.rs",
    "src/persistent_inner.rs",
    "src/proxy.rs",
    # Issue #4034: PKCS#11/HSM-backed KeySource (behind #[cfg(feature =
    # "pkcs11_keysource")]; cfg'd out of the default build).
    "src/pkcs11_keysource.rs",
    # Issue #4034 supply-chain follow-up: the OWNED safe wrapper over the raw
    # cryptoki-sys FFI bindings (replaces the high-level cryptoki crate +
    # transitive unmaintained `paste`). Same `pkcs11_keysource` feature gate.
    "src/pkcs11_native.rs",
    # Issue #4030: online OCSP client-cert revocation (behind #[cfg(feature =
    # "online_ocsp")]; cfg'd out of the default build).
    "src/ocsp.rs",
    # Issue #4028: Redis-backed shared atomic ReplayCache (behind #[cfg(feature =
    # "redis_replay")]; cfg'd out of the default build).
    "src/redis_store.rs",
    # Issue #69 (epic #68 v0.4 Axis 1): etcd-backed CP / LINEARIZABLE shared atomic
    # ReplayCache (behind #[cfg(feature = "cpstore_etcd")]; cfg'd out of the default
    # build).
    "src/etcd_store.rs",
    # ADR-MCPS-020: declared replay-store durability tier (deployment assertion).
    "src/replay_tier.rs",
    # ADR-MCPS-021 Axis 2: declared revocation tier (Tier 1 bounded-cache / Tier 2
    # live / Tier 3 push) — semantic names + honest per-tier guarantee. Pure type.
    "src/revocation_tier.rs",
    # ADR-MCPS-021 Tier 2: live strong trust check (no positive caching, optional
    # second live revocation authority, fail-closed on outage).
    "src/live_trust.rs",
    # ADR-MCPS-021 Tier 3: push-invalidation trust cache (bounded-T cache + injected
    # invalidation channel; bounded-T fallback when the channel is unhealthy).
    "src/push_trust.rs",
    "src/rlimits.rs",
    # Issue #3865 / #4039: OS sandbox profile + fail-closed platform gate, plus the
    # Linux Landlock/seccomp ENFORCEMENT backend (sandbox_linux.rs is
    # #[cfg(target_os = "linux")] — excluded from the Mac build entirely).
    "src/sandbox.rs",
    "src/sandbox_linux.rs",
    # Issue #3837: shared, server-side-atomic replay cache (backend-agnostic core +
    # in-memory reference store). Always compiled; default-build, Bazel-tested.
    "src/shared_replay.rs",
    "src/tls.rs",
    # ADR-MCPRE-051 Phase 2 (§1): opt-in async serving path. #[cfg(feature =
    # "async_serve")] — compiled ONLY by the `:mcp_re_proxy_async` flavor + its
    # tests; the default/production flavors see an absent module and link no
    # tokio/hyper (ADR-MCPS-018 lean-sync firewall).
    "src/async_serve.rs",
    # MCPRE-113 (ADR-MCPRE-051 §1, Phase 2): the per-core serving fleet (per-core
    # tokio runtimes + SO_REUSEPORT listeners + Linux CPU pinning). Same
    # #[cfg(feature = "async_serve")] gate as async_serve.rs — invisible to the
    # default closure.
    "src/async_fleet.rs",
    # MCPRE-117 (ADR-MCPRE-051 §4, Phase 2): the async authoritative replay tier seam
    # (async store contract + L1-never-Fresh wrapper). Same #[cfg(feature =
    # "async_serve")] gate — invisible to the default closure.
    "src/async_replay.rs",
    "src/transport.rs",
    # ADR-MCPS-021: bounded trust-propagation cache (revocation window T).
    "src/trust_cache.rs",
    # MCPS-84 (ADR-MCPS-049 W2): trust-epoch invalidation source (Redis reader is
    # redis_replay-gated inside the module).
    "src/trust_epoch.rs",
]

# Single source of truth for the mcp_re_proxy library deps. All three library
# instances compile the SAME `_PROXY_LIB_SRCS`, so they MUST link the same crates —
# they differ ONLY by `crate_features`. Sharing the list here prevents per-instance
# dep drift (which previously left `:mcp_re_proxy_fault` / `:mcp_re_proxy_dev_env`
# pointing at a removed `rustls-pemfile` and missing `zeroize`).
_PROXY_LIB_DEPS = [
    "//mcp-re-core:mcp_re_core",
    "//mcp-re-policy:mcp_re_policy",
    # MCPS-58 (ADR-023 §A1): CRL parsing for the static --client-crl freshness gate.
    "@crates_mcp_re//:der",
    "@crates_mcp_re//:libc",
    "@crates_mcp_re//:rustls",
    "@crates_mcp_re//:rustls-pki-types",
    "@crates_mcp_re//:serde_json",
    "@crates_mcp_re//:thiserror",
    "@crates_mcp_re//:x509-cert",
    "@crates_mcp_re//:x509-parser",
    # MCPS-076 (audit gap G-3): scrub raw-seed temporaries in key_source.
    "@crates_mcp_re//:zeroize",
]

# Issue #4039: the Linux kernel-sandbox crates are TARGET-gated. sandbox_linux.rs
# (in _PROXY_LIB_SRCS) is #[cfg(target_os = "linux")], so EVERY library instance
# needs landlock+seccompiler when built for Linux and NONE of them on Mac — the
# select() resolves to [] off-Linux, keeping the Mac build's closure unchanged.
_PROXY_LINUX_SANDBOX_DEPS = select({
    "@platforms//os:linux": [
        "@crates_mcp_re//:landlock",
        "@crates_mcp_re//:seccompiler",
    ],
    "//conditions:default": [],
})

# Issue #4028/#4030/#4034: deps for the all-external-backends library flavor.
# _PROXY_LIB_DEPS + the optional backend crates (enabled together by the three
# feature flags) + the Linux sandbox select. The default `:mcp_re_proxy` does NOT
# use this — only `:mcp_re_proxy_ext` and its tests do, so the default closure
# stays lean (ADR-MCPS-018).
# The optional backend crates as a PLAIN list (no select) — nt_rust_test's `deps`
# cannot contain a select(), so test targets reuse this and inherit the
# target-gated sandbox crates transitively via the linked `:mcp_re_proxy_ext`.
_PROXY_EXT_CRATES = [
    # #4034 supply-chain fix: the raw PKCS#11 FFI bindings (libloading only, no
    # transitive `paste`). The high-level `cryptoki` crate is replaced by the
    # owned safe wrapper in src/pkcs11_native.rs.
    "@crates_mcp_re//:cryptoki-sys",
    "@crates_mcp_re//:redis",
    "@crates_mcp_re//:ureq",
    # ADR-MCPS-028 §B: SigV4 HMAC-SHA256 + KMS standard-base64 message/signature
    # encoding for the AWS KMS Ed25519 signer (feature aws_kms_keysource).
    "@crates_mcp_re//:hmac",
    "@crates_mcp_re//:base64",
    "@crates_mcp_re//:x509-ocsp",
    # NOTE: der + x509-cert moved to _PROXY_LIB_DEPS — the base crate's static-CRL
    # freshness gate (MCPS-58, tls.rs) now uses them, so ext inherits them via LIB.
    "@crates_mcp_re//:spki",
    "@crates_mcp_re//:sha2",
    # #4063 (MCPS-088): OS CSPRNG for the per-request OCSP nonce.
    "@crates_mcp_re//:getrandom",
    # #4063 (MCPS-088): asn1-rs BitString for the responder-signature verify path
    # (part of the online_ocsp module; linked by every ext flavor).
    "@crates_mcp_re//:asn1-rs",
]

_PROXY_EXT_DEPS = _PROXY_LIB_DEPS + _PROXY_EXT_CRATES + _PROXY_LINUX_SANDBOX_DEPS

# The three Mac-buildable external-backend features, enabled together by the
# `:mcp_re_proxy_ext` flavor and its tests. (Sandbox enforcement is target-gated,
# not feature-gated, so it is NOT in this list.)
_PROXY_EXT_FEATURES = [
    "pkcs11_keysource",
    "redis_replay",
    # #69 (epic #68 v0.4 Axis 1): etcd-backed CP / LINEARIZABLE shared replay store.
    "cpstore_etcd",
    "online_ocsp",
    # ADR-MCPS-028 §B: native AWS KMS Ed25519 response signer.
    "aws_kms_keysource",
    # ADR-MCPS-028 §C: native GCP Cloud KMS Ed25519 response signer.
    "gcp_kms_keysource",
]

# MCPS-029 (folds in MCPS-018 #3807): the production sidecar CLI. Terminates TLS,
# verifies object signatures + (optional) authz + transport binding, forwards to
# an inner MCP server subprocess, signs responses. Blocking; no async runtime.
nt_rust_binary(
    name = "mcp_re_proxy_cli",
    srcs = ["src/main.rs"],
    edition = "2021",
    deps = [
        ":mcp_re_proxy",
        # #220 (ADR-MCPS-048): main.rs uses mcp_re_core directly (e.g.
        # `mcp_re_core::ReplayDurabilityClass`), so it must link mcp-re-core — the Cargo
        # build resolved this transitively/by-manifest but the Bazel binary target
        # never listed it, which is the head of the #220 fail-to-build cascade.
        "//mcp-re-core:mcp_re_core",
        "//mcp-re-policy:mcp_re_policy",
        # MCPS-88 (ADR-MCPS-049 W3): main.rs installs a SIGTERM/SIGINT handler via
        # libc::sigaction for graceful drain, so the binary must link libc (the
        # Cargo build resolves it by manifest; the Bazel binary target must list it).
        "@crates_mcp_re//:libc",
        # MCPRE-116 (ADR-MCPRE-051 §6): main.rs names rustls_pki_types cert/key types
        # in the CRL hot-reload task signature.
        "@crates_mcp_re//:rustls-pki-types",
    ],
)

