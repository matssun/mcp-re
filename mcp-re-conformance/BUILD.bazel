        "//mcp-re-host:BUILD.bazel",
        "//mcp-re-policy:BUILD.bazel",
        "//mcp-re-policy:tests/vectors/phase5_vectors.json",
        "//mcp-re-proxy:BUILD.bazel",
        "//mcp-re-stdio-bridge:BUILD.bazel",
        "//mcp-re-demo:BUILD.bazel",
        "//mcp-re-demo-server:BUILD.bazel",
        "//mcp-re-transport:BUILD.bazel",
        "//mcp-re-demo-fileserver:BUILD.bazel",
    ],
