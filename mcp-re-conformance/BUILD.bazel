        "MCP_RE_MANIFEST": "$(rlocationpath conformance_manifest.json)",
        "MCP_RE_CORE_MANIFEST": "$(rlocationpath //mcp-re-core:tests/vectors/manifest.json)",
        "MCP_RE_PHASE5": "$(rlocationpath //mcp-re-policy:tests/vectors/phase5_vectors.json)",
