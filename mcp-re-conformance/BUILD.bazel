# ADR-MCPS-034 (extends ADR-MCPS-030): static method-name drift guard. Scans the
# NON-TEST mcp-re-core/src for banned concrete MCP method-name literals
# (tools/list, tools/call, resources/list, resources/read, prompts/list,
# prompts/get, sampling/createMessage, completion/complete) and FAILS if any is
# added to production Core. The Core src tree is delivered as data (runfiles);
# the guard resolves lib.rs and scans its parent dir from DISK, with the
# mcp-re-test-paths cargo fallback — the same scheme as the drift_guard.
nt_rust_test(
    name = "method_name_drift_guard_test",
    srcs = ["tests/method_name_drift_guard_test.rs"],
    auto_cargo_toml = False,
    bazel_build_cfg = False,
    data = [
        "//mcp-re-core:src_files",
        "//mcp-re-core:src/lib.rs",
    ],
    edition = "2021",
    env = {
        "MCP_RE_CORE_SRC_LIB": "$(rlocationpath //mcp-re-core:src/lib.rs)",
    },
    deps = [
        "//mcp-re-test-paths:mcp_re_test_paths",
        "@crates_mcp_re//:serde_json",
    ],
)

# ADR-MCPS-035: audit-evidence vocabulary drift guard. Asserts the MCP-RE audit
# vocabulary (mcp-re-core/src/audit.rs) derives every rejection reason from the
# frozen McpReError::wire_code() taxonomy (mcp-re-core/src/error.rs is the sole
# authority) and that the success-event set is EXACTLY the two-item allowlist.
# Both Core source files are delivered as data (runfiles); the guard reads them
# from DISK (via $(rlocationpath), with the mcp-re-test-paths cargo fallback) — the
