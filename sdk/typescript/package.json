{
  "name": "@mcp-re/sdk",
  "version": "0.1.0",
  "description": "MCP-RE TypeScript SDK — runtime-evidence security (signed requests, verified responses) for the MCP TypeScript SDK, via a transport adapter over the audited mcp-re-client-core.",
  "license": "Apache-2.0",
  "author": "Mats Sundvall",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./transport": {
      "types": "./dist/transport.d.ts",
      "default": "./dist/transport.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "transport": [
        "dist/transport.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "native/binding.js",
    "native/binding.d.ts",
    "native/*.node"
  ],
  "napi": {
    "binaryName": "mcp-re-sdk-core",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build:native": "napi build --platform --release --manifest-path Cargo.toml --output-dir native --js binding.js --dts binding.d.ts",
    "build:native:debug": "napi build --platform --manifest-path Cargo.toml --output-dir native --js binding.js --dts binding.d.ts",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:native && npm run build:ts",
    "test": "npm run build && vitest run"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.16.0 <2.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.16.0",
    "@napi-rs/cli": "^3.7.2",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
